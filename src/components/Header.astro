---
import { defaultWhatsappMessage, navItems, SITE_NAME, whatsappLink } from "../data/site";

const contactUrl = whatsappLink(defaultWhatsappMessage);
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line/70 bg-white/95 shadow-sm backdrop-blur-md">
  <div class="mx-auto flex min-h-20 max-w-7xl flex-col gap-3 px-4 py-4 sm:px-6 md:flex-row md:items-center md:justify-between md:py-0 lg:px-8">
    <a href="#inicio" class="font-serif text-2xl font-medium tracking-normal text-foreground">
      {SITE_NAME}
    </a>

    <nav class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm font-medium text-muted md:justify-end md:text-base">
      {navItems.map((item) => (
        <a class="transition-colors hover:text-sage" href={item.href}>
          {item.label}
        </a>
      ))}
      <a
        href={contactUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-sage px-5 py-2.5 text-center text-white transition-colors hover:bg-sage-dark"
      >
        Reserva por WhatsApp
      </a>
    </nav>
  </div>
</header>
