---
import {
  defaultWhatsappMessage,
  INSTAGRAM_URL,
  navItems,
  SITE_NAME,
  whatsappLink,
} from "../data/site";
import packageJson from "../../package.json";

const year = new Date().getFullYear();
const contactUrl = whatsappLink(defaultWhatsappMessage);
const appVersion = packageJson.version;
---

<footer class="bg-foreground px-4 py-16 text-white sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 grid gap-12 md:grid-cols-3">
      <div class="space-y-4">
        <h2 class="text-2xl text-white">{SITE_NAME}</h2>
        <p class="leading-relaxed text-white/70">
          Clases de yoga para bienestar, flexibilidad y equilibrio
        </p>
      </div>

      <div class="space-y-4">
        <h2 class="font-sans text-lg font-medium text-white">Enlaces rápidos</h2>
        <nav class="flex flex-col space-y-2">
          {navItems.slice(0, 4).map((item) => (
            <a href={item.href} class="text-white/70 transition hover:text-white">
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="space-y-4">
        <h2 class="font-sans text-lg font-medium text-white">Conecta</h2>
        <div class="flex gap-4">
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-sm font-semibold transition hover:bg-white/20"
            aria-label="Instagram de Yoga Con Mar"
          >
            IG
          </a>
          <a
            href={contactUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-sm font-semibold transition hover:bg-white/20"
            aria-label="WhatsApp de Yoga Con Mar"
          >
            WA
          </a>
        </div>
      </div>
    </div>

    <div class="space-y-2 border-t border-white/10 pt-8 text-center text-white/60">
      <p>&copy; {year} {SITE_NAME}.</p>
      <p class="text-xs text-white/40">v{appVersion}</p>
    </div>
  </div>
</footer>
