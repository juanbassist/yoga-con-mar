---
import { whatsappLink } from "../data/site";

const contactUrl = whatsappLink("Hola Mar, quiero empezar mi practica de yoga hoy");
---

<section class="section-pad relative overflow-hidden bg-gradient-to-br from-clay to-sand">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl space-y-8 text-center">
    <h2 class="text-3xl text-white sm:text-4xl lg:text-5xl">
      Empieza tu práctica hoy
    </h2>
    <p class="mx-auto max-w-2xl text-xl leading-relaxed text-white/90">
      Da el primer paso hacia una vida con más equilibrio y bienestar.
    </p>
    <a
      href={contactUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block rounded-full bg-white px-12 py-5 text-lg font-medium text-clay shadow-2xl transition hover:-translate-y-0.5 hover:bg-background sm:px-16 sm:py-6 sm:text-xl"
    >
      Contactar por WhatsApp
    </a>
  </div>
</section>
